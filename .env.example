# Morai — Required Environment Variables
# Copy to .env for local development. Never commit .env with real secrets.
# All vars are Zod-parsed at boot; missing or invalid vars cause a loud exit naming the offending var.

# ── Postgres ─────────────────────────────────────────────────────────────────
# Supabase DIRECT/session connection (port 5432). Required by BOTH server and worker.
# Do NOT use the 6543 transaction pooler — migrations and pg-boss require the direct connection.
# Supabase Dashboard → Project Settings → Database → Connection string (Session mode, port 5432)
DATABASE_URL=postgres://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Optional: Supabase transaction pooler (port 6543). Not used in Phase 1.
# Set only if API connection count becomes a constraint in later phases.
# DATABASE_POOL_URL=postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ── MCP Bearer Auth ──────────────────────────────────────────────────────────
# Bearer token for the /mcp endpoint. Minimum 16 characters.
# Set on the server Railway service only. Generate with: openssl rand -hex 32
MCP_BEARER_TOKEN=replace-with-a-random-32-char-secret

# ── Server ───────────────────────────────────────────────────────────────────
# HTTP port for the Hono server. Railway injects this automatically on deployed services.
# Defaults to 3000 for local development.
PORT=3000

# ── Worker ───────────────────────────────────────────────────────────────────
# Timezone for pg-boss cron alignment. Set on the worker Railway service.
TZ=America/New_York
