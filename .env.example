# Morai — environment contract (placeholders only; never commit real secrets).
# Source of truth: apps/server/src/config.ts + apps/worker/src/config.ts (Zod schemas).
# Railway: deploy/build config lives in railway.server.toml / railway.worker.toml (IaC).
#   Secrets/vars CANNOT live in config-as-code — set them as Railway variables
#   (recommend PROJECT-LEVEL SHARED variables so server + worker share one source).

# ── Database (server + worker) ───────────────────────────────────────────────
# Supabase session pooler, port 5432 (direct/session URL; used by runMigrations + pg-boss).
DATABASE_URL=postgresql://USER:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres
# Optional pooler URL for pg-boss; falls back to DATABASE_URL if unset.
DATABASE_POOL_URL=

# ── Server (apps/server) ─────────────────────────────────────────────────────
MCP_BEARER_TOKEN=                 # required, >= 16 chars (MCP /mcp auth)
PORT=3000                         # default 3000
TZ=America/New_York               # default
NODE_ENV=production               # development | production | test

# ── Token encryption (server + worker) ───────────────────────────────────────
TOKEN_ENCRYPTION_KEY=             # required, >= 32 chars (pgcrypto broker_tokens)

# ── Schwab brokerage — trader + market apps (server + worker) ─────────────────
SCHWAB_TRADER_APP_KEY=
SCHWAB_TRADER_APP_SECRET=
SCHWAB_TRADER_CALLBACK_URL=https://127.0.0.1:8443/oauth-callback
SCHWAB_MARKET_APP_KEY=
SCHWAB_MARKET_APP_SECRET=
SCHWAB_MARKET_CALLBACK_URL=https://127.0.0.1:8443/oauth-callback

# ── Worker tunables (apps/worker) — all optional, sane defaults ───────────────
FRED_API_KEY=                     # optional; absent → 4.5% rate fallback
BSM_MAX_DTE=90
BSM_STRIKE_BAND_PCT=0.10
BSM_DIVIDEND_YIELD=0.013
BSM_RATE_FALLBACK=0.045
